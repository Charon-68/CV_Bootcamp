# NexusGuard Configuration

# App
NEXUSGUARD_ENV=development
NEXUSGUARD_API_HOST=0.0.0.0
NEXUSGUARD_API_PORT=8000
NEXUSGUARD_LOG_LEVEL=info

# AI core
NEXUSGUARD_LLM_BASE_URL=http://reasoner:8080/v1
NEXUSGUARD_LLM_TOKEN=reasoner-REPLACE_ME
NEXUSGUARD_LLM_CHAT_MODEL=auto
NEXUSGUARD_LLM_EMBED_MODEL=text-embedding-3-small

# Database (Postgres)
NEXUSGUARD_DB_URL=postgresql+psycopg://nexusguard:nexusguard@postgres:5432/nexusguard

# Vision
NEXUSGUARD_YOLO_WEIGHTS=vision/models/yolov8n.pt
